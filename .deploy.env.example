# Copy to `.deploy.env` (gitignored) and edit.
# Used by tools/deploy.ps1.

# Preferred: a Host alias from ~/.ssh/config, so SSH key, user, and address
# are resolved by OpenSSH without ever appearing here.
DEPLOY_HOST_ALIAS=Shuttle2
DEPLOY_DOC_ROOT=/var/www/html/controller

# Alternative if you don't have an SSH config alias:
# DEPLOY_HOST_ALIAS=user@192.168.1.232
# (paired with `IdentityFile` set globally or a -i flag added to the script).

# Where the mock controller (mock/) pushes status JSON. Read by mock/pusher.py
# at startup. Override per-run with an env var of the same name.
MOCK_TARGET_BASE_URL=http://192.168.20.232/controller
MOCK_INTERVAL_S=10

# Must match GH_SECRET_TOKEN in httproot/config.php on the deployed server.
# Set this whenever you rotate the secret on the server, or pushes will be
# silently dropped (HTTP 204) and the dashboard will stay empty.
MOCK_SECRET=REPLACE_ME_WITH_THE_SAME_VALUE_AS_GH_SECRET_TOKEN
