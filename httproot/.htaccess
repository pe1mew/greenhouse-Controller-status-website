# Site-wide hardening for the greenhouse status website.
# Per-directory rules live in data/.htaccess and log/logs/.htaccess.

# ── Security headers (apply on success and error responses alike) ─────────
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header always set X-Frame-Options            "DENY"
    Header always set X-Content-Type-Options     "nosniff"
    Header always set Referrer-Policy            "same-origin"
    # CSP: 'unsafe-inline' is required because index.php injects window.GH_CFG
    # as an inline <script> and log/index.php has a small inline <style> block.
    # XSS surface is independently neutralised by `textContent`-only rendering
    # (see TR-26 / FR-39); CSP here is defence in depth.
    Header always set Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
    Header always set X-Robots-Tag               "noindex, nofollow"
    # Strip server-disclosure headers when the host lets us.
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ── Force HTTPS, defensive (provider may already do this upstream) ────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Block direct GET on config files ──────────────────────────────────────
# PHP processes them to a 0-byte body anyway, but defence in depth.
<FilesMatch "^config(_template)?\.php$">
    Require all denied
</FilesMatch>

# ── Block dotfiles (.env, .ht*, .git*, etc.) ──────────────────────────────
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
